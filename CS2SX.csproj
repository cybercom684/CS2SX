<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<PackAsTool>true</PackAsTool>
		<ToolCommandName>cs2sx</ToolCommandName>
		<PackageId>CS2SX</PackageId>
		<Version>0.4.0.202</Version>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
		<EmbeddedResource Include="Runtime\switchapp.h" />
		<EmbeddedResource Include="Runtime\switchforms.h" />
		<EmbeddedResource Include="Stubs\SwitchApp.cs" />
		<EmbeddedResource Include="Stubs\Input.cs" />
		<EmbeddedResource Include="Stubs\LibNX\**\*" />
		<EmbeddedResource Include="SwitchFormsLib\**\*.cs" />
	</ItemGroup>
	<ItemGroup>
		<Compile Remove="Stubs\LibNX\**\*" />
		<Compile Remove="SwitchFormsLib\**\*" />
		<Compile Remove="cs2sx_out\**\*" />
	</ItemGroup>
</Project>